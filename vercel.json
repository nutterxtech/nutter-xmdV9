{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/dashboard build",
  "outputDirectory": "artifacts/dashboard/dist/public",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
